{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Casualty Record",
  "type": "object",
  "required": [
    "casualty_id",
    "date",
    "latitude",
    "longitude",
    "verification",
    "confidence",
    "sources",
    "status"
  ],
  "properties": {
    "casualty_id": {
      "type": "string",
      "pattern": "^CAS-[0-9]{4}-[0-9]{6}$"
    },
    "name": { "type": "string" },
    "age": { "type": ["integer", "null"], "minimum": 0 },
    "gender": { "type": "string", "enum": ["male", "female", "unknown"] },
    "date": { "type": "string", "format": "date" },
    "latitude": { "type": "number", "minimum": 31.2, "maximum": 31.6 },
    "longitude": { "type": "number", "minimum": 34.2, "maximum": 34.6 },
    "location_name": { "type": "string" },
    "hospital": { "type": "string" },
    "associated_strike": { "type": "string" },
    "verification": {
      "type": "string",
      "enum": ["confirmed", "probable", "reported", "disputed"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": {
      "type": "string",
      "enum": ["killed", "injured", "missing"]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    }
  }
}

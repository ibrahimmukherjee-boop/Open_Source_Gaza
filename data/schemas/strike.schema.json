{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Strike Record",
  "type": "object",
  "required": [
    "strike_id",
    "date",
    "latitude",
    "longitude",
    "verification",
    "confidence",
    "sources"
  ],
  "properties": {
    "strike_id": {
      "type": "string",
      "pattern": "^GAZA-[0-9]{4}-[0-9]{6}$"
    },
    "date": { "type": "string", "format": "date" },
    "time": { "type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
    "latitude": { "type": "number", "minimum": 31.2, "maximum": 31.6 },
    "longitude": { "type": "number", "minimum": 34.2, "maximum": 34.6 },
    "munition": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "verification": {
      "type": "string",
      "enum": ["confirmed", "probable", "reported", "disputed"]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["news", "hospital", "un", "ngo", "satellite", "video", "witness"]
          }
        }
      }
    },
    "destroyed_buildings": { "type": "integer", "minimum": 0 },
    "hospital_damage": { "type": "boolean" },
    "school_damage": { "type": "boolean" },
    "casualties_reported": { "type": "integer", "minimum": 0 },
    "description": { "type": "string" },
    "facility_type": {
      "type": "string",
      "enum": ["residential", "hospital", "school", "mosque", "infrastructure", "refugee_camp", "commercial", "unknown"]
    },
    "revision_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "author": { "type": "string" },
          "change": { "type": "string" }
        }
      }
    }
  }
}
